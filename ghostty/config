# Migrated from webterm/wezterm.lua.
# This file only carries over the static settings that map cleanly to Ghostty.
# The WezTerm-specific Lua automation for startup sizing/positioning and popup
# windows is intentionally not represented here.

# Font configuration
font-family = JetBrainsMono Nerd Font
font-family = JetBrains Mono Nerd Font
font-family = JetBrains Mono
font-family = Apple Color Emoji
font-size = 14

# Colors
# Custom dogrun palette migrated from webterm/colors/dogrun.toml.
background = #222433
foreground = #9ea3c0
background-opacity = 0.98
cursor-color = #9ea3c0
cursor-text = #222433
selection-background = #363e7f

palette = 0=#111219
palette = 1=#e58585
palette = 2=#7cbe8c
palette = 3=#8e8a6f
palette = 4=#4c89ac
palette = 5=#6c75cb
palette = 6=#73c1a9
palette = 7=#9ea3c0
palette = 8=#545c8c
palette = 9=#b871b8
palette = 10=#7cbe8c
palette = 11=#a8a384
palette = 12=#589ec6
palette = 13=#929be5
palette = 14=#59b6b6
palette = 15=#9ea3c0

# Window appearance
macos-titlebar-style = hidden
window-width = 240
window-height = 60

# Layout
adjust-cell-height = 0

# Scrollback
scrollback-limit = 1000

# Quick terminal
quick-terminal-position=bottom
quick-terminal-size=50%

# Bell
# Ghostty keeps BEL features disabled by default, which matches the WezTerm setup.

# Keybindings
keybind = global:cmd+alt+ctrl+shift+f=toggle_quick_terminal
