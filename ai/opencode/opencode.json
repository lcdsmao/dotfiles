{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "curl *": "deny",
      "wget *": "deny",
      "*base64 -D*": "deny",
      "*base64 --decode*": "deny",
      "*base64 -d*": "deny",
      "* | bash": "deny",
      "* | zsh": "deny",
      "* | sh": "deny",
      "eval *": "deny"
    },
    "external_directory": {
      "~/Library/Application Support/rtk/*": "allow"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    }
  },
  "agent": {
    "build": {
      "color": "secondary"
    },
    "plan": {
      "color": "accent"
    }
  }
}
